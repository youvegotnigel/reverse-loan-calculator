{
  "name": "reverse-loan-calculator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Reverse loan calculator for Sri Lanka — from salary to maximum borrowing power.",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @rlc/web",
    "build": "npm run build -w @rlc/web",
    "preview": "npm run preview -w @rlc/web",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.5.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
